### launch_presale handler (DAMM v2)

```rust
pub fn handler(ctx: Context<LaunchPresale>) -> Result<()> {
    let state = &mut ctx.accounts.presale_state;

    require!(!state.launched, PresaleError::AlreadyLaunched);
    require!(state.total_raised >= state.raise_target, PresaleError::RaiseTargetNotMet);

    let mint_key = ctx.accounts.mint.key();
    let presale_seeds = &[b"presale", mint_key.as_ref(), &[state.state_bump]];
    let signer = &[&presale_seeds[..]];

    // ── Step 1: Wrap SOL into WSOL ────────────────────────────────────────────
    // Transfer 85 SOL from vault to presale_state's WSOL ATA, then sync_native
    **ctx.accounts.vault.try_borrow_mut_lamports()? -= 85_000_000_000;
    **ctx.accounts.wsol_ata.try_borrow_mut_lamports()? += 85_000_000_000;

    token::sync_native(CpiContext::new_with_signer(
        ctx.accounts.token_program.to_account_info(),
        token::SyncNative { account: ctx.accounts.wsol_ata.to_account_info() },
        signer,
    ))?;

    // ── Step 2: CPI → DAMM v2 initialize_customizable_pool ───────────────────
    // Build the instruction data manually using DAMM v2's IDL discriminator,
    // or use the damm-v2 Rust SDK crate if added as a dependency.
    //
    // Key parameters:
    //   tokenAAmount = 85_000_000_000  (85 WSOL)
    //   tokenBAmount = 500_000_000_000_000  (500M tokens, 50% of supply)
    //   sqrtMinPrice = MIN_SQRT_PRICE  (full range)
    //   sqrtMaxPrice = MAX_SQRT_PRICE  (full range)
    //   poolFees:
    //     baseFee.cliffFeeNumerator = 500_000_000  (50% cliff)
    //     baseFee.numberOfPeriod = 120
    //     baseFee.reductionFactor = 432  (exponential, decays to ~1% in 2h)
    //     baseFee.periodFrequency = 60   (seconds)
    //     baseFee.feeSchedulerMode = 1   (exponential)
    //     dynamicFee = enabled (default params)
    //     protocolFeePercent = 20        (Meteora takes 20% of LP fee — standard)
    //   collectFeeMode = 1  (OnlyB = SOL fees only)
    //   activationType = 1  (timestamp)
    //   activationPoint = 0 (open immediately)
    //   hasAlphaVault = false

    // After the CPI, the pool is created and the position NFT is minted
    // to presale_state's position_nft_account.

    // ── Step 3: Permanently lock the position ─────────────────────────────────
    // CPI → DAMM v2 permanent_lock_position
    // This makes the liquidity unremovable — rug-proof.
    // IMPORTANT: even with permanent lock, claim_fee still works on this position.
    // That is the key Meteora feature that enables fee distribution to contributors.

    // ── Step 4: Close WSOL ATA to recover rent ───────────────────────────────
    token::close_account(CpiContext::new_with_signer(
        ctx.accounts.token_program.to_account_info(),
        token::CloseAccount {
            account: ctx.accounts.wsol_ata.to_account_info(),
            destination: ctx.accounts.presale_state.to_account_info(),
            authority: ctx.accounts.presale_state.to_account_info(),
        },
        signer,
    ))?;

    // ── Step 5: Record state ──────────────────────────────────────────────────
    state.position_nft_mint = ctx.accounts.position_nft_mint.key();
    state.pool = ctx.accounts.pool.key();
    state.tokens_per_lamport_x64 = ((state.distribution_amount as u128) << 64)
        / (state.total_raised as u128);
    state.launched = true;

    emit!(PresaleLaunched {
        mint: ctx.accounts.mint.key(),
        pool: ctx.accounts.pool.key(),
        position_nft: ctx.accounts.position_nft_mint.key(),
        total_raised: state.total_raised,
        lp_amount: state.lp_tokens_amount,
        distribution_amount: state.distribution_amount,
    });

    Ok(())
}
```

