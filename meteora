### lib/meteora.ts (new file)

```typescript
import { Connection, PublicKey } from "@solana/web3.js";
import {
  CpAmm,
  CollectFeeMode,
  BaseFeeMode,
  ActivationType,
  MIN_SQRT_PRICE,
  MAX_SQRT_PRICE,
  getBaseFeeParams,
  getDynamicFeeParams,
} from "@meteora-ag/cp-amm-sdk";
import BN from "bn.js";

export const DAMM_V2_PROGRAM = new PublicKey(
  "cpamdpZCGKUy5JxQXB4dcpGPiikHawvSWAd6mEn1sGG"
);

// Derive the DAMM v2 pool address given two token mints
// Sort mints: lower pubkey = token A, higher = token B
export function getDammV2PoolAddress(mintA: PublicKey, mintB: PublicKey) {
  const [tokenA, tokenB] = mintA.toBuffer().compare(mintB.toBuffer()) < 0
    ? [mintA, mintB]
    : [mintB, mintA];

  return PublicKey.findProgramAddressSync(
    [tokenA.toBuffer(), tokenB.toBuffer()],
    DAMM_V2_PROGRAM
  );
}

// Fee params for anti-sniper memetoken launch
export function getMemetokenFeeParams(tokenBDecimals: number) {
  return {
    baseFee: getBaseFeeParams(
      {
        baseFeeMode: BaseFeeMode.FeeTimeSchedulerExponential,
        feeTimeSchedulerParam: {
          startingFeeBps: 5000,  // 50% cliff — destroys snipers
          endingFeeBps: 100,     // 1% floor
          numberOfPeriod: 120,
          totalDuration: 7200,   // 2 hours to decay
        },
      },
      tokenBDecimals,
      ActivationType.Timestamp
    ),
    compoundingFeeBps: 0,
    padding: 0,
    dynamicFee: getDynamicFeeParams(25), // 0.25% max dynamic add-on
  };
}

// Used on the frontend to display estimated fee at current time
export function estimateCurrentFeeBps(
  launchTimestamp: number,
  nowTimestamp: number
): number {
  const elapsed = nowTimestamp - launchTimestamp;
  const decayDuration = 7200; // 2 hours
  const progress = Math.min(1, elapsed / decayDuration);
  // Exponential approximation
  const fee = 5000 * Math.pow(100 / 5000, progress);
  return Math.max(100, Math.round(fee));
}
```

### buildLaunchPresaleTx update

The `buildLaunchPresaleTx` function needs additional accounts for DAMM v2.
The position NFT keypair is generated client-side and passed to the tx:

```typescript
export async function buildLaunchPresaleTx(
  program: any,
  caller: PublicKey,
  mint: PublicKey,
): Promise<{ tx: Transaction; positionNftKeypair: Keypair }> {
  const positionNftKeypair = Keypair.generate();
  const [presaleState] = findPresaleState(mint);
  const [vault] = findVault(mint);
  const [tokenVault] = findTokenVault(mint);
  const [feeVault] = findFeeVault(mint); // new PDA

  const WSOL = new PublicKey("So11111111111111111111111111111111111111112");
  const wsolAta = getAssociatedTokenAddressSync(WSOL, presaleState, true);

  // Derive DAMM v2 pool
  const [pool] = getDammV2PoolAddress(WSOL, mint);

  // Position account (DAMM v2 PDA from position NFT mint)
  const [position] = PublicKey.findProgramAddressSync(
    [Buffer.from("position"), positionNftKeypair.publicKey.toBuffer()],
    DAMM_V2_PROGRAM
  );

  const positionNftAccount = getAssociatedTokenAddressSync(
    positionNftKeypair.publicKey,
    presaleState,
    true
  );

  // ... build and return tx + positionNftKeypair
  // Note: positionNftKeypair must sign the tx

  return { tx, positionNftKeypair };
}
```

### New: `buildClaimPoolFeesTx` and `buildCollectMyFeesTx`

```typescript
// Anyone can call this (crank or contributor) to pull fees from DAMM v2 into fee_vault
export async function buildClaimPoolFeesTx(
  program: any,
  caller: PublicKey,
  mint: PublicKey,
): Promise<Transaction> {
  const [presaleState] = findPresaleState(mint);
  const [feeVault] = findFeeVault(mint);
  // ... accounts for DAMM v2 claim_fee CPI
  return await program.methods
    .claimPoolFees()
    .accounts({ caller, mint, presaleState, feeVault, /* damm v2 accounts */ })
    .transaction();
}

// Contributor calls this to pull their accumulated fee share
export async function buildCollectMyFeesTx(
  program: any,
  contributor: PublicKey,
  mint: PublicKey,
): Promise<Transaction> {
  const [presaleState] = findPresaleState(mint);
  const [feeVault] = findFeeVault(mint);
  const [contributionState] = findContribution(mint, contributor);

  return await program.methods
    .collectMyFees()
    .accounts({ contributor, mint, presaleState, feeVault, contributionState })
    .transaction();
}

export function findFeeVault(mint: PublicKey) {
  return PublicKey.findProgramAddressSync(
    [Buffer.from("fee_vault"), mint.toBuffer()],
    PROGRAM_ID
  );
}
```

