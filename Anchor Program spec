**Logic:**
```rust
pub fn handler(ctx: Context<InitializePresale>, params: InitializePresaleParams) -> Result<()> {
    // Validate params
    require!(params.token_name.len() <= 32, PresaleError::NameTooLong);
    require!(params.token_ticker.len() <= 10, PresaleError::TickerTooLong);
    require!(params.duration_seconds >= 3600, PresaleError::DurationTooShort);
    require!(params.duration_seconds <= 604800, PresaleError::DurationTooLong);

    let launch_fee: u64 = 1_000_000_000; // 1 SOL

    // Transfer launch fee to treasury
    anchor_lang::system_program::transfer(
        CpiContext::new(
            ctx.accounts.system_program.to_account_info(),
            anchor_lang::system_program::Transfer {
                from: ctx.accounts.creator.to_account_info(),
                to: ctx.accounts.treasury.to_account_info(),
            },
        ),
        launch_fee,
    )?;

    let total_supply: u64 = 1_000_000_000_000_000; // 1B tokens with 6 decimals

    // Mint 100% of supply to token_vault PDA
    // (PDA is the mint authority, so we sign with PDA seeds)
    let mint_key = ctx.accounts.mint.key();
    let seeds = &[b"presale", mint_key.as_ref(), &[ctx.bumps.presale_state]];
    let signer = &[&seeds[..]];

    token::mint_to(
        CpiContext::new_with_signer(
            ctx.accounts.token_program.to_account_info(),
            token::MintTo {
                mint: ctx.accounts.mint.to_account_info(),
                to: ctx.accounts.token_vault.to_account_info(),
                authority: ctx.accounts.presale_state.to_account_info(),
            },
            signer,
        ),
        total_supply,
    )?;

    // Create on-chain metadata via Metaplex
    // CPI to token metadata program
    // (use mpl_token_metadata::instruction::create_metadata_accounts_v3)

    let now = Clock::get()?.unix_timestamp;

    let state = &mut ctx.accounts.presale_state;
    state.mint = ctx.accounts.mint.key();
    state.token_name = params.token_name;
    state.token_ticker = params.token_ticker;
    state.token_uri = params.token_uri;
    state.description = params.description;
    state.creator = ctx.accounts.creator.key();
    state.raise_target = 85_000_000_000; // 85 SOL in lamports
    state.total_supply = total_supply;
    state.lp_tokens_amount = total_supply / 2;
    state.distribution_amount = total_supply / 2;
    state.total_raised = 0;
    state.total_contributors = 0;
    state.start_time = now;
    state.end_time = now + params.duration_seconds;
    state.launched = false;
    state.refund_enabled = false;
    state.tokens_per_lamport_x64 = 0;
    state.vault_bump = ctx.bumps.presale_state; // store separately if needed
    state.token_vault_bump = ctx.bumps.token_vault;
    state.state_bump = ctx.bumps.presale_state;
    state.twitter = params.twitter;
    state.telegram = params.telegram;
    state.website = params.website;

    emit!(PresaleCreated {
        mint: ctx.accounts.mint.key(),
        creator: ctx.accounts.creator.key(),
        end_time: state.end_time,
    });

    Ok(())
}
```

