### 2. `contribute`

User contributes SOL to the presale vault.

```rust
pub fn contribute(ctx: Context<Contribute>, amount_lamports: u64) -> Result<()>
```

**Accounts:**
```rust
#[derive(Accounts)]
pub struct Contribute<'info> {
    #[account(mut)]
    pub contributor: Signer<'info>,

    pub mint: Account<'info, Mint>,

    #[account(
        mut,
        seeds = [b"presale", mint.key().as_ref()],
        bump = presale_state.state_bump,
    )]
    pub presale_state: Account<'info, PresaleState>,

    /// CHECK: Native SOL vault PDA — we manage lamports directly
    #[account(
        mut,
        seeds = [b"vault", mint.key().as_ref()],
        bump,
    )]
    pub vault: UncheckedAccount<'info>,

    #[account(
        init_if_found,
        payer = contributor,
        space = CONTRIBUTION_STATE_SIZE,
        seeds = [b"contribution", mint.key().as_ref(), contributor.key().as_ref()],
        bump,
    )]
    pub contribution_state: Account<'info, ContributionState>,

    /// CHECK: Treasury for platform fees
    #[account(mut, constraint = treasury.key() == TREASURY_PUBKEY)]
    pub treasury: UncheckedAccount<'info>,

    pub system_program: Program<'info, System>,
}
```

**Logic:**
```rust
pub fn handler(ctx: Context<Contribute>, amount_lamports: u64) -> Result<()> {
    let state = &mut ctx.accounts.presale_state;
    let now = Clock::get()?.unix_timestamp;

    // Guards
    require!(!state.launched, PresaleError::AlreadyLaunched);
    require!(!state.refund_enabled, PresaleError::PresaleFailed);
    require!(now < state.end_time, PresaleError::PresaleEnded);
    require!(amount_lamports >= 10_000_000, PresaleError::AmountTooSmall); // 0.01 SOL minimum

    // Platform fee: 1% of contribution
    let platform_fee = amount_lamports / 100;
    let net_amount = amount_lamports - platform_fee;

    // Check max contribution per wallet
    let contribution = &mut ctx.accounts.contribution_state;
    if state.max_contribution > 0 {
        require!(
            contribution.amount_contributed + net_amount <= state.max_contribution,
            PresaleError::ExceedsMaxContribution
        );
    }

    // Check would not exceed raise target
    require!(
        state.total_raised + net_amount <= state.raise_target,
        PresaleError::ExceedsRaiseTarget
    );

    // Transfer fee to treasury
    anchor_lang::system_program::transfer(
        CpiContext::new(
            ctx.accounts.system_program.to_account_info(),
            anchor_lang::system_program::Transfer {
                from: ctx.accounts.contributor.to_account_info(),
                to: ctx.accounts.treasury.to_account_info(),
            },
        ),
        platform_fee,
    )?;

    // Transfer net amount to vault
    anchor_lang::system_program::transfer(
        CpiContext::new(
            ctx.accounts.system_program.to_account_info(),
            anchor_lang::system_program::Transfer {
                from: ctx.accounts.contributor.to_account_info(),
                to: ctx.accounts.vault.to_account_info(),
            },
        ),
        net_amount,
    )?;

    // Update contribution state
    if contribution.amount_contributed == 0 {
        contribution.contributor = ctx.accounts.contributor.key();
        contribution.mint = ctx.accounts.mint.key();
        contribution.claimed = false;
        contribution.refunded = false;
        contribution.bump = ctx.bumps.contribution_state;
        state.total_contributors += 1;
    }
    contribution.amount_contributed += net_amount;
    state.total_raised += net_amount;

    emit!(ContributionMade {
        mint: ctx.accounts.mint.key(),
        contributor: ctx.accounts.contributor.key(),
        amount: net_amount,
        total_raised: state.total_raised,
    });

    Ok(())
}
```

