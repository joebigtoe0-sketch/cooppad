import { PublicKey } from "@solana/web3.js";
import { PROGRAM_ID } from "./anchor";

export function findPresaleState(mint: PublicKey) {
  return PublicKey.findProgramAddressSync(
    [Buffer.from("presale"), mint.toBuffer()],
    PROGRAM_ID
  );
}

export function findVault(mint: PublicKey) {
  return PublicKey.findProgramAddressSync(
    [Buffer.from("vault"), mint.toBuffer()],
    PROGRAM_ID
  );
}

export function findTokenVault(mint: PublicKey) {
  return PublicKey.findProgramAddressSync(
    [Buffer.from("token_vault"), mint.toBuffer()],
    PROGRAM_ID
  );
}

export function findContribution(mint: PublicKey, contributor: PublicKey) {
  return PublicKey.findProgramAddressSync(
    [Buffer.from("contribution"), mint.toBuffer(), contributor.toBuffer()],
    PROGRAM_ID
  );
}
