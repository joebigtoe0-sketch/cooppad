### GET /api/presales — List all presales

```typescript
// app/api/presales/route.ts
import { NextRequest, NextResponse } from "next/server";
import { prisma } from "@/lib/prisma";

export async function GET(req: NextRequest) {
  const { searchParams } = new URL(req.url);
  const filter = searchParams.get("filter") || "live"; // live | ended | launched
  const page = parseInt(searchParams.get("page") || "1");
  const limit = 20;

  const now = new Date();

  let where: any = {};
  if (filter === "live") {
    where = { launched: false, refundEnabled: false, endTime: { gt: now } };
  } else if (filter === "ended") {
    where = { launched: false, endTime: { lt: now } };
  } else if (filter === "launched") {
    where = { launched: true };
  }

  const [presales, total] = await Promise.all([
    prisma.presale.findMany({
      where,
      orderBy: { totalRaised: "desc" },
      skip: (page - 1) * limit,
      take: limit,
      select: {
        mint: true,
        tokenName: true,
        tokenTicker: true,
        imageUrl: true,
        description: true,
        totalRaised: true,
        raiseTarget: true,
        totalContributors: true,
        endTime: true,
        launched: true,
        refundEnabled: true,
      },
    }),
    prisma.presale.count({ where }),
  ]);

  return NextResponse.json({
    presales: presales.map((p) => ({
      ...p,
      totalRaised: p.totalRaised.toString(),
      raiseTarget: p.raiseTarget.toString(),
      progressPercent: Math.min(
        100,
        Math.round((Number(p.totalRaised) / Number(p.raiseTarget)) * 100)
      ),
    })),
    total,
    pages: Math.ceil(total / limit),
  });
}

// POST — called after tx confirms, to register presale in DB
export async function POST(req: NextRequest) {
  const body = await req.json();

  const presale = await prisma.presale.create({
    data: {
      mint: body.mint,
      creator: body.creator,
      tokenName: body.tokenName,
      tokenTicker: body.tokenTicker,
      description: body.description,
      imageUrl: body.imageUrl,
      metadataUri: body.metadataUri,
      twitter: body.twitter || null,
      telegram: body.telegram || null,
      website: body.website || null,
      startTime: new Date(),
      endTime: new Date(Date.now() + body.durationSeconds * 1000),
    },
  });

  return NextResponse.json({ presale });
}
