## Database Schema (Prisma)

```prisma
// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Presale {
  id              String   @id @default(cuid())
  mint            String   @unique        // Solana mint pubkey (base58)
  creator         String                  // Creator wallet pubkey
  
  // Token info (mirrors what's on chain but queryable)
  tokenName       String
  tokenTicker     String
  description     String
  imageUrl        String                  // IPFS image URL
  metadataUri     String                  // IPFS metadata JSON URI
  
  // Social links
  twitter         String?
  telegram        String?
  website         String?
  
  // Presale state (synced from chain via webhooks)
  totalRaised     BigInt   @default(0)    // Lamports
  totalContributors Int    @default(0)
  raiseTarget     BigInt   @default(85000000000) // 85 SOL
  startTime       DateTime
  endTime         DateTime
  launched        Boolean  @default(false)
  refundEnabled   Boolean  @default(false)
  
  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  contributions   Contribution[]
  
  @@index([launched])
  @@index([endTime])
  @@index([totalRaised])
}

model Contribution {
  id              String   @id @default(cuid())
  mint            String
  contributor     String                  // Wallet pubkey
  amountContributed BigInt               // Lamports (net, after fee)
  claimed         Boolean  @default(false)
  refunded        Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  presale         Presale  @relation(fields: [mint], references: [mint])
  
  @@unique([mint, contributor])
  @@index([contributor])
}

model WebhookEvent {
  id              String   @id @default(cuid())
  signature       String   @unique
  type            String                  // "PresaleCreated", "ContributionMade", etc.
  mint            String?
  processed       Boolean  @default(false)
  rawData         Json
  createdAt       DateTime @default(now())
}
```

