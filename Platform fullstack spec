### hooks/usePresale.ts

```typescript
"use client";
import { useConnection } from "@solana/wallet-adapter-react";
import { useEffect, useState } from "react";
import { PublicKey } from "@solana/web3.js";
import { findPresaleState } from "@/lib/pda";
import { getProgram } from "@/lib/anchor";
import { AnchorProvider } from "@coral-xyz/anchor";

export interface PresaleOnChainState {
  mint: string;
  totalRaised: bigint;
  raiseTarget: bigint;
  totalContributors: number;
  endTime: Date;
  launched: boolean;
  refundEnabled: boolean;
  progressPercent: number;
}

export function usePresale(mintAddress: string) {
  const { connection } = useConnection();
  const [state, setState] = useState<PresaleOnChainState | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);

  useEffect(() => {
    if (!mintAddress) return;

    const fetchState = async () => {
      try {
        const mint = new PublicKey(mintAddress);
        const [presaleStatePda] = findPresaleState(mint);

        // Use a read-only provider
        const provider = new AnchorProvider(connection, {} as any, {});
        const program = getProgram(provider);

        const data = await program.account.presaleState.fetch(presaleStatePda);

        const totalRaised = BigInt(data.totalRaised.toString());
        const raiseTarget = BigInt(data.raiseTarget.toString());

        setState({
          mint: mintAddress,
          totalRaised,
          raiseTarget,
          totalContributors: data.totalContributors,
          endTime: new Date(data.endTime.toNumber() * 1000),
          launched: data.launched,
          refundEnabled: data.refundEnabled,
          progressPercent: Math.min(
            100,
            Math.round(Number(totalRaised) / Number(raiseTarget) * 100)
          ),
        });
      } catch (e) {
        setError("Failed to load presale state");
        console.error(e);
      } finally {
        setLoading(false);
      }
    };

    fetchState();

    // Poll every 10 seconds for live updates
    const interval = setInterval(fetchState, 10_000);
    return () => clearInterval(interval);
  }, [mintAddress, connection]);

  return { state, loading, error };
}
```

