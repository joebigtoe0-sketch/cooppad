import { useState } from "react";
import { useWallet, useConnection } from "@solana/wallet-adapter-react";
import { Keypair, Transaction } from "@solana/web3.js";
import { WalletMultiButton } from "@solana/wallet-adapter-react-ui";
import { uploadImageToPinata, uploadMetadataJson } from "@/lib/pinata";
import { buildInitializePresaleTx } from "@/lib/instructions";
import { getProgram } from "@/lib/anchor";
import { AnchorProvider } from "@coral-xyz/anchor";

type Step = 1 | 2 | 3;

export function LaunchForm() {
  const { publicKey, sendTransaction, signTransaction } = useWallet();
  const { connection } = useConnection();
  const [step, setStep] = useState<Step>(1);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const [tokenName, setTokenName] = useState("");
  const [tokenTicker, setTokenTicker] = useState("");
  const [description, setDescription] = useState("");
  const [imageFile, setImageFile] = useState<File | null>(null);
  const [imagePreview, setImagePreview] = useState<string | null>(null);
  const [durationSeconds, setDurationSeconds] = useState(86400);
  const [maxContribution, setMaxContribution] = useState(0);
  const [twitter, setTwitter] = useState("");
  const [telegram, setTelegram] = useState("");
  const [website, setWebsite] = useState("");

  const handleImageChange = (file: File) => {
    setImageFile(file);
    setImagePreview(URL.createObjectURL(file));
  };

  const handleLaunch = async () => {
    if (!publicKey || !imageFile) return;
    setLoading(true);
    setError(null);

    try {
      // Step 1: Upload image
      const imageUrl = await uploadImageToPinata(imageFile);

      // Step 2: Upload metadata JSON
      const metadataUri = await uploadMetadataJson({
        name: tokenName,
        symbol: tokenTicker,
        description,
        image: imageUrl,
        twitter,
        telegram,
        website,
      });

      // Step 3: Build transaction (new mint keypair each time)
      const mint = Keypair.generate();

      const provider = new AnchorProvider(connection, {
        publicKey,
        signTransaction: signTransaction!,
        signAllTransactions: async (txs) => txs,
      }, { commitment: "confirmed" });

      const program = getProgram(provider);

      const tx = await buildInitializePresaleTx(program, publicKey, mint.publicKey, {
        tokenName,
        tokenTicker,
        tokenUri: metadataUri,
        description,
        durationSeconds,
        maxContribution: maxContribution * 1_000_000_000, // SOL → lamports
        twitter,
        telegram,
        website,
      });

      // mint keypair must also sign (it's the new mint account)
      tx.feePayer = publicKey;
      tx.recentBlockhash = (await connection.getLatestBlockhash()).blockhash;
      tx.partialSign(mint);

      const sig = await sendTransaction(tx, connection, {
        signers: [],
        skipPreflight: false,
      });

      await connection.confirmTransaction(sig, "confirmed");

      // Step 4: Register in DB
      await fetch("/api/presales", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          mint: mint.publicKey.toBase58(),
          creator: publicKey.toBase58(),
          tokenName,
          tokenTicker,
          description,
          imageUrl,
          metadataUri,
          twitter,
          telegram,
          website,
          durationSeconds,
        }),
      });

      // Redirect to presale page
      window.location.href = `/presale/${mint.publicKey.toBase58()}`;
    } catch (e: any) {
      setError(e.message || "Transaction failed");
    } finally {
      setLoading(false);
    }
  };

  // Render step UI...
  // Step 1: token name, ticker, description, image upload
  // Step 2: duration selector, max contribution, socials
  // Step 3: fee breakdown, launch button
}
```

