# Copy to .env.local for Next.js (must live in moonpad/, same folder as package.json)

# Default dev: http://localhost:3040 (`npm run dev` = webpack). Use `npm run dev:turbo`
# only if you need Turbopack — it can break `/api/presales` (PublicKey / Anchor decode).
# Webpack dev ignores Anchor's `target/` tree via next.config watchOptions.

# Solana RPC (use devnet or Helius in production)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Deployed MoonPad program (must match Anchor declare_id after deploy)
NEXT_PUBLIC_PROGRAM_ID=8XvnK9bVHYXqkbwfaRiEFzxyPbKNEZTY1yJzm5JGrctJ

# Must match on-chain PLATFORM_AUTHORITY_PUBKEY in programs/moonpad/src/constants.rs
NEXT_PUBLIC_PLATFORM_AUTHORITY=C7bttWUQDVGjxtUpAh1n18vRwQrbTaxV2kVmMkgD16xF

# Put the matching 64-byte secret in .env.local (gitignored), e.g.:
# PLATFORM_AUTHORITY_SECRET=[1,2,3,...]
# Generate with: solana-keygen new --outfile platform.json
# or Node: Keypair.generate() → JSON.stringify(Array.from(keypair.secretKey))

# Per-mint treasury secrets are appended to moonpad/.data/treasury-by-mint.json
# (gitignored). Server code resolves this file even when `next dev` runs with cwd =
# the monorepo root (see lib/server/moonpadDataPath.ts).

# Mint addresses (…coop): pre-mine on the server and store in .data/mint-pool.json:
#   node scripts/mine-mint-pool.cjs 100
# Optional 3rd arg: worker count (default ≈ CPU cores − 1). Do NOT use
# `solana-keygen grind --ends-with` alone on CLI 1.18.x — it skips almost all
# keypairs due to a bug; this repo’s script uses parallel worker_threads instead.
# Lay-an-egg pops one entry per request; empty pool returns HTTP 503.

# Home lists live presales from .data/treasury-by-mint.json (eggs laid through this app).
# Set true to also merge every on-chain PresaleState via getProgramAccounts (RPC-heavy).
NEXT_PUBLIC_LIST_PRESALES_FROM_CHAIN=false

# --- Metaplex / IPFS (optional but required for cover image → on-chain metadata) ---
# Server-only JWT from https://pinata.cloud — never commit the real value.
# PINATA_JWT=eyJ...
# Optional dedicated gateway (shorter URLs help stay under the 200-byte on-chain uri cap):
# PINATA_GATEWAY=https://mygateway.mypinata.cloud
# Default image in JSON when no cover file is uploaded (HTTPS URL):
# PINATA_DEFAULT_TOKEN_IMAGE_URL=https://example.com/default-token.png
# Alternatives: Cloudflare R2, NFT.Storage — implement behind the same API shape later.

# Post–raise-target hatch delay: default on-chain build is 60s (dev). Mainnet program is built with
# `--features mainnet` (3600s). Keep `lib/presaleConstants.ts` `POST_GOAL_LAUNCH_DELAY_SECS` in sync.

# --- Auto hatch + Meteora (server cron) ---
# CRON_SECRET=long-random-string
# Hit POST or GET /api/cron/complete-eggs with Authorization: Bearer <CRON_SECRET>
# (or ?secret= for manual tests). Uses treasury-by-mint.json + PLATFORM_AUTHORITY_SECRET.
# DISABLE_AUTO_METEORA_POOL=1   # only run launch_presale, skip sweep/pool/register

# Optional: require Bearer for POST /api/presale/finish-liquidity (otherwise open — lock down in prod)
# LIQUIDITY_WEBHOOK_SECRET=long-random-string

# --- Robinhood Chain bonding curve (primary product) ---
# Active EVM chain: robinhood | robinhoodTestnet | local (anvil)
NEXT_PUBLIC_EVM_CHAIN=local

# Deployed CoopLaunchpad address on the active chain (evm/script/Deploy.s.sol,
# or `npm run evm:local` against anvil for local dev)
NEXT_PUBLIC_LAUNCHPAD_ADDRESS=

# RPC overrides (defaults exist for mainnet/testnet/local; set when they differ)
# NEXT_PUBLIC_ROBINHOOD_RPC_URL=
# NEXT_PUBLIC_ROBINHOOD_TESTNET_RPC_URL=
# NEXT_PUBLIC_LOCAL_RPC_URL=http://127.0.0.1:8545

# WalletConnect Cloud project id — without it only injected wallets (MetaMask etc.) work
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# IPFS gateway for resolving ipfs:// token images in the browser
# NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud

# Indexer storage: Postgres in production (Railway plugin sets DATABASE_URL).
# Unset locally = embedded PGlite under .data/curve-pglite (zero setup).
# DATABASE_URL=postgres://user:pass@host:5432/db

# Indexer tuning
# EVM_INDEXER_START_BLOCK=0     # first run: backfill from this block (default: current head)
# EVM_INDEXER_DISABLED=1        # turn the in-process indexer off
