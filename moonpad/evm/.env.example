# RPC endpoints (referenced by foundry.toml [rpc_endpoints]) — verified 2026-07-14
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com

# Canonical Uniswap v2 on Robinhood Chain MAINNET (chain 4663), verified live.
# The TESTNET (46630) has no public Uniswap v2 — use script/DeployLocal.s.sol
# there, which deploys WETH + Uniswap v2 + the launchpad together.
UNIV2_FACTORY=0x8bcEaA40B9AcdfAedF85AdF4FF01F5Ad6517937f
UNIV2_ROUTER=0x89e5db8b5aa49aa85ac63f691524311aeb649eba

# Platform treasury that accrues trade/graduation fees
FEE_RECIPIENT=

# Deployer key for forge script --broadcast (never commit a real key)
DEPLOYER_KEY=
